rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Simple role check (expects users/{uid}.role == "admin")
    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Public catalog reads
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users + per-user cart
    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;

      match /cart/{productId} {
        // Per-user isolated cart
        allow read, write: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // Orders
    match /orders/{orderId} {
      // Customer can create their own order, pending only.
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.paymentStatus == "pending"
        && request.resource.data.orderStatus == "pending";

      // Customer can read their own orders; admin can read all.
      allow read: if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();

      // Recommended: only backend/admin updates status fields.
      allow update: if isAdmin();

      allow delete: if false;
    }

    // Payment transactions (audit trail) - backend/admin only
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

